---
/**
 * QuickStart — compact local onramp that links to canonical docs for detail.
 */
import CodeBlock from './CodeBlock.astro';
import HelloWorldWorkflowViewer from './HelloWorldWorkflowViewer';
import { site } from '../data/site';
import { firstEntityCommands } from '../data/install';
---

<section
  class="section section--alt"
  id="install-get-started"
  aria-labelledby="quickstart-heading"
>
  <div class="container">
    <div class="quickstart">
      <div class="quickstart__copy">
        <h2 class="section-heading" id="quickstart-heading">
          Install and get started
        </h2>

        <p class="quickstart__framing">
          The shortest useful path: install the binary, start the local server,
          import the lifecycle workflow for an entity model, create an entity
          instance, move it through a valid transition, and read the state back.
          The graph shows the HelloWorld entity workflow: the states,
          transitions, criteria, and processors attached to that entity.
        </p>

        <ol class="quickstart__steps">
          <li>
            <strong>Install:</strong>
            <code>brew install cyoda-platform/cyoda-go/cyoda</code>
          </li>
          <li>
            <strong>Run:</strong>
            <code>cyoda</code>
            starts the local server on <code>localhost:8080</code>.
          </li>
          <li>
            <strong>Authenticate locally:</strong>
            mock auth is the default, so no bearer token is required.
          </li>
          <li>
            <strong>Keep going:</strong>
            use the docs for entity schemas, workflow processors, criteria,
            deployment options, and API reference.
          </li>
        </ol>

        <a
          href={site.docsQuickstart}
          class="quickstart__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          &rarr; Full install guide on docs.cyoda.net
        </a>

      </div>

      <div
        class="workflow-artifact"
        aria-label="HelloWorld entity workflow editor"
      >
        <div class="workflow-artifact__header">
          <div>
            <p class="workflow-artifact__eyebrow">Entity workflow</p>
            <h3 class="workflow-artifact__title">HelloWorld</h3>
            <p class="workflow-artifact__subtitle">
              Lifecycle for the HelloWorld example entity
            </p>
          </div>
          <span class="workflow-artifact__badge">Editable</span>
        </div>
        <div class="workflow-artifact__canvas">
          <HelloWorldWorkflowViewer client:only="react" />
        </div>
      </div>

      <div class="quickstart__commands">
        <CodeBlock
          code={firstEntityCommands}
          language="bash"
          label="orders-entity-lifecycle.sh"
        />
      </div>
    </div>
  </div>
</section>
