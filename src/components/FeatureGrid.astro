---
/**
 * FeatureGrid — 4-column responsive grid with inline SVG sprite.
 * Spec reference: section 13, section 23.
 *
 * SVG icon sprite is embedded once here. FeatureCard uses <use href="#id">.
 * All icons are 24x24, accent-primary colour.
 */
import FeatureCard from './FeatureCard.astro';
import type { Feature } from '../data/features';

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<!-- Hidden SVG sprite — icons referenced by FeatureCard via <use> -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  style="display:none"
  aria-hidden="true"
>
  <!-- icon-memory: lightning bolt -->
  <symbol id="icon-memory" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
  </symbol>

  <!-- icon-postgres: database cylinder -->
  <symbol id="icon-postgres" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="12" cy="5" rx="9" ry="3"/>
    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
  </symbol>

  <!-- icon-workflow: git branch / state machine -->
  <symbol id="icon-workflow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="18" cy="18" r="3"/>
    <circle cx="6" cy="6" r="3"/>
    <path d="M6 21V9a9 9 0 0 0 9 9"/>
  </symbol>

  <!-- icon-grpc: plug / connection -->
  <symbol id="icon-grpc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
    <polyline points="15 3 21 3 21 9"/>
    <line x1="10" y1="14" x2="21" y2="3"/>
  </symbol>

  <!-- icon-history: clock / history -->
  <symbol id="icon-history" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="12 8 12 12 14 14"/>
    <path d="M3.05 11a9 9 0 1 0 .5-4"/>
    <polyline points="3 3 3 7 7 7"/>
  </symbol>

  <!-- icon-languages: code brackets -->
  <symbol id="icon-languages" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="16 18 22 12 16 6"/>
    <polyline points="8 6 2 12 8 18"/>
  </symbol>

  <!-- icon-test: beaker / test tube -->
  <symbol id="icon-test" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M14.5 2v17.5c0 1.4-1.1 2.5-2.5 2.5h0c-1.4 0-2.5-1.1-2.5-2.5V2"/>
    <path d="M8.5 2h7"/>
    <path d="M14.5 16h-5"/>
  </symbol>

  <!-- icon-deploy: rocket -->
  <symbol id="icon-deploy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
    <path d="m3.5 11.5 9-9a1 1 0 0 1 1.5 0l3 3a1 1 0 0 1 0 1.5l-9 9"/>
    <path d="M13 7h4a2 2 0 0 1 2 2v4"/>
  </symbol>
</svg>

<div
  class="feature-grid"
  aria-label="Key capabilities"
>
  {features.map((feature) => (
    <FeatureCard
      iconId={feature.iconId}
      title={feature.title}
      description={feature.description}
    />
  ))}
</div>
