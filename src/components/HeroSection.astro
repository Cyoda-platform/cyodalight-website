---
/**
 * HeroSection — two-column hero: prose left, install panel right.
 * Spec reference: section 9, section 23.
 */
import Badge from './Badge.astro';
import InstallPanel from './InstallPanel.astro';
import { site } from '../data/site';
import { installTabs } from '../data/install';
---

<section
  class="hero hero--grid-bg"
  id="hero"
  aria-labelledby="hero-heading"
>
  <div class="container">
    <div class="hero__inner">
      <!-- Left column: text -->
      <div class="hero__text">
        <div class="hero__badge">
          <Badge label="Open Source · Apache 2.0" variant="accent" />
        </div>

        <h1 class="hero__headline" id="hero-heading">
          The open-source EDBMS with a built-in workflow engine.
        </h1>

        <p class="hero__subhead">
          Cyoda manages stateful entities, enforces lifecycle transitions,
          and keeps a complete audit trail. Single binary. Zero dependencies
          in memory mode.
        </p>

        <div class="hero__actions">
          <a
            href={site.docsQuickstart}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get started &rarr;
          </a>
          <a
            href={site.github}
            class="btn btn--text"
          >
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Right column: install panel -->
      <div class="hero__panel">
        <InstallPanel tabs={installTabs} panelId="hero-install" />

        <p class="hero__confirm">
          <span class="hero__confirm-check">&#10003;</span>
          Zero dependencies in memory mode
          &nbsp;&middot;&nbsp;
          Starts in under 2 seconds
        </p>
      </div>
    </div>
  </div>
</section>
