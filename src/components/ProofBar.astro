---
/**
 * ProofBar — horizontal language and tech credibility strip.
 * Spec reference: section 10, section 23.
 *
 * All icons are inline SVG. No external CDN. No hover effects. No links.
 * Language mark colours follow official brand guidelines (approximate).
 */
---

<div class="proof-bar" aria-label="Compatible technologies">
  <div class="container">
    <div class="proof-bar__inner">
      <span class="proof-bar__label">Compatible with:</span>

      <ul class="proof-bar__items" role="list" aria-label="Supported languages">
        <!-- Java -->
        <li class="proof-bar__item">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <!-- Java: simplified "cup" mark in Duke orange -->
            <title>Java</title>
            <path
              d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149M8.276 15.933s-1.028.761.542.924c2.032.209 3.636.227 6.413-.308 0 0 .384.389.987.602-5.679 1.661-12.007.13-7.942-1.218M13.116 11.475c1.158 1.333-.304 2.533-.304 2.533s2.939-1.518 1.589-3.418c-1.261-1.772-2.228-2.652 3.007-5.688 0-.001-8.216 2.051-4.292 6.573"
              fill="#E76F00"
            />
            <path
              d="M19.33 20.504s.679.559-.747.991c-2.712.822-11.288 1.069-13.669.033-.856-.373.749-.891 1.254-.999.527-.114.828-.093.828-.093-.953-.671-6.156 1.317-2.643 1.887C14.012 23.74 22 21.195 19.33 20.504M9.292 13.21s-4.362 1.036-1.544 1.412c1.189.159 3.561.123 5.77-.062 1.806-.152 3.618-.477 3.618-.477s-.637.272-1.098.587c-4.429 1.165-12.986.623-10.522-.568 2.082-1.006 3.776-.892 3.776-.892M17.116 17.584c4.503-2.34 2.421-4.589.968-4.285-.355.074-.515.138-.515.138s.132-.207.385-.297c2.875-1.011 5.086 2.981-.928 4.562 0-.001.07-.062.09-.118"
              fill="#E76F00"
            />
            <path
              d="M14.401 0s2.494 2.494-2.365 6.33c-3.896 3.077-.888 4.832-.001 6.836-2.274-2.053-3.943-3.858-2.824-5.539 1.644-2.469 6.197-3.665 5.19-7.627"
              fill="#E76F00"
            />
          </svg>
          Java
        </li>

        <!-- Python -->
        <li class="proof-bar__item">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
          >
            <title>Python</title>
            <path
              d="M11.914 0C5.82 0 6.2 2.656 6.2 2.656l.007 2.752h5.814v.826H3.9S0 5.789 0 11.969c0 6.18 3.403 5.963 3.403 5.963h2.031v-2.867s-.109-3.403 3.347-3.403h5.77s3.24.052 3.24-3.131V3.19S18.302 0 11.914 0zM8.708 1.84a1.047 1.047 0 1 1 0 2.095 1.047 1.047 0 0 1 0-2.095z"
              fill="#366994"
            />
            <path
              d="M12.086 24c6.094 0 5.714-2.656 5.714-2.656l-.007-2.752H12v-.826h8.1S24 18.211 24 12.031c0-6.18-3.403-5.963-3.403-5.963h-2.031v2.867s.109 3.403-3.347 3.403H9.449s-3.24-.052-3.24 3.131v5.31S5.698 24 12.086 24zm3.206-1.84a1.047 1.047 0 1 1 0-2.094 1.047 1.047 0 0 1 0 2.094z"
              fill="#FFD43B"
            />
          </svg>
          Python
        </li>

        <!-- Go -->
        <li class="proof-bar__item">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
          >
            <title>Go</title>
            <path
              d="M1.811 10.231c-.047 0-.058-.023-.035-.059l.246-.315c.023-.035.081-.058.128-.058h4.172c.046 0 .058.035.035.07l-.199.303c-.023.036-.082.07-.117.07zM.047 11.306c-.047 0-.059-.023-.035-.058l.245-.316c.023-.035.082-.058.129-.058h5.328c.047 0 .07.035.058.07l-.093.28c-.012.047-.058.07-.105.07zm2.828 1.075c-.047 0-.059-.035-.035-.07l.163-.292c.023-.035.07-.07.117-.07h2.337c.047 0 .07.035.07.082l-.023.28c0 .047-.047.082-.082.082zm12.129-2.36c-.745.199-1.257.35-1.991.55-.18.046-.192.058-.35-.122-.178-.2-.308-.33-.548-.448-.737-.362-1.45-.257-2.116.175-.795.514-1.201 1.274-1.19 2.22.012.935.654 1.692 1.577 1.819.795.105 1.46-.175 1.98-.77.105-.13.198-.27.315-.434H10.59c-.257 0-.315-.163-.234-.373.163-.386.46-1.033.632-1.362a.34.34 0 0 1 .315-.198h4.593c-.024.316-.024.631-.07.947a4.983 4.983 0 0 1-.958 2.29c-.841 1.11-1.96 1.808-3.35 2.008-1.155.164-2.241-.047-3.19-.7-1.001-.678-1.58-1.61-1.74-2.81-.198-1.49.35-2.798 1.388-3.876a5.418 5.418 0 0 1 3.36-1.62c1.132-.093 2.2.14 3.14.805.655.456 1.12 1.074 1.413 1.821.058.163.023.245-.175.303z"
              fill="#00ACD7"
            />
            <path
              d="M17.58 13.32c.188-.07.37-.094.549.07.34.3.654.62.98.924.198.187.21.35.046.572-.327.432-.665.853-1.016 1.26a.353.353 0 0 1-.49.069l-.96-.912a.367.367 0 0 1-.047-.502l.938-1.48zm-4.22 6.195a.344.344 0 0 1-.35-.256l-.327-1.284c-.047-.175.047-.303.21-.338.397-.094.805-.164 1.202-.222.175-.024.338.07.362.245l.257 1.308c.035.175-.07.315-.245.327l-1.11.22z"
              fill="#00ACD7"
            />
          </svg>
          Go
        </li>

        <!-- Kotlin -->
        <li class="proof-bar__item">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
          >
            <title>Kotlin</title>
            <path
              d="M24 24H0L12.501 11.498 24 24z"
              fill="#EF4C3D"
            />
            <path
              d="M0 24V0l12.5 12.5L24 0v24"
              fill="url(#kotlin-gradient)"
            />
            <defs>
              <linearGradient id="kotlin-gradient" x1="0" y1="0" x2="24" y2="24">
                <stop offset="0%" stop-color="#7951FF"/>
                <stop offset="100%" stop-color="#EF4C3D"/>
              </linearGradient>
            </defs>
          </svg>
          Kotlin
        </li>
      </ul>

      <span class="proof-bar__divider" aria-hidden="true"></span>

      <span class="proof-bar__pill">gRPC API</span>
      <span class="proof-bar__pill">Apache 2.0</span>
      <span class="proof-bar__pill">Open Source</span>
    </div>
  </div>
</div>
