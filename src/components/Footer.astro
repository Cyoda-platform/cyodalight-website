---
/**
 * Footer — wordmark, licence, links, copyright.
 * Spec reference: section 17, section 23.
 */
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__inner">
      <!-- Wordmark -->
      <a href={base} class="footer__wordmark" aria-label="Cyoda home">
        Cyoda
      </a>

      <!-- Tagline -->
      <p class="footer__tagline">
        Open source under the Apache 2.0 License.<br />
        Built by <a href={site.cyoda} target="_blank" rel="noopener noreferrer">Cyoda</a>.
      </p>

      <!-- Links -->
      <ul class="footer__links" role="list">
        <li>
          <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        </li>
        <li>
          <a href={site.docs}>docs.cyoda.net</a>
        </li>
        <li>
          <a href={site.cyodaCloud}>Cyoda Cloud</a>
        </li>
        <li>
          <a href={site.cyoda}>Enterprise Cyoda</a>
        </li>
      </ul>

      <!-- Copyright -->
      <p class="footer__copyright">
        &copy; {site.copyrightYear} {site.copyrightHolder}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
