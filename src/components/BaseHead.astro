---
/**
 * BaseHead — renders all <head> content.
 * Spec references: sections 7.3, 18, 19, 20, 21.
 */
import { site, version } from '../data/site';

const base = import.meta.env.BASE_URL;

// @font-face declarations are built here so that font paths are correctly
// prefixed with the deployment base path (e.g. /cyodalight-website/).
// CSS url() paths cannot use import.meta.env so they live in JS-land instead.
const fontFaceCSS = `
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('${base}fonts/inter/inter-latin-400-normal.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url('${base}fonts/inter/inter-latin-600-normal.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url('${base}fonts/inter/inter-latin-700-normal.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
  font-family: 'JetBrains Mono';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('${base}fonts/jetbrains-mono/jetbrains-mono-latin-400-normal.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
`;

interface StructuredDataObject {
  [key: string]: unknown;
}

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  structuredData?: StructuredDataObject[];
}

const {
  title = site.title,
  description = site.description,
  canonicalUrl = site.url + '/',
  structuredData = [],
} = Astro.props;

// JSON-LD: SoftwareApplication — spec section 20
const softwareAppSchema: StructuredDataObject = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Cyoda',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows',
  programmingLanguage: ['Go', 'Java', 'Python', 'Kotlin'],
  description:
    'Cyoda is an open-source entity database management system (EDBMS) and workflow runtime. Define entity types, enforce lifecycle transitions, and query temporal history. Single binary. SQLite-backed local storage by default.',
  url: site.url,
  downloadUrl: site.githubReleases,
  softwareVersion: version,
  license: site.licenseUrl,
  author: {
    '@type': 'Organization',
    name: site.copyrightHolder,
    url: site.cyoda,
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

// JSON-LD: BreadcrumbList — single-item for homepage
const breadcrumbSchema: StructuredDataObject = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Cyoda',
      item: site.url,
    },
  ],
};

const allSchemas = [softwareAppSchema, breadcrumbSchema, ...structuredData];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="icon" href={`${base}favicon.ico`} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={site.url} />
<meta property="og:title" content={site.ogTitle} />
<meta property="og:description" content={site.ogDescription} />
<meta property="og:image" content={`${site.url}${site.ogImage}`} />
<meta property="og:image:width" content={String(site.ogImageWidth)} />
<meta property="og:image:height" content={String(site.ogImageHeight)} />

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={site.ogTitle} />
<meta name="twitter:description" content={site.twitterDescription} />
<meta name="twitter:image" content={`${site.url}${site.ogImage}`} />

<!-- Font preloads — above-fold fonts only, to avoid render blocking -->
<link rel="preload" href={`${base}fonts/inter/inter-latin-700-normal.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${base}fonts/inter/inter-latin-400-normal.woff2`} as="font" type="font/woff2" crossorigin />

<!-- Font face declarations (base-path-aware, cannot live in static CSS) -->
<style is:global set:html={fontFaceCSS}></style>

<!-- JSON-LD Structured Data -->
{allSchemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
