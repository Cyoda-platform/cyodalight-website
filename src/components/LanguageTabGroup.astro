---
/**
 * LanguageTabGroup — Java / Python / Go / Kotlin tab switcher.
 * Spec reference: section 12, section 23.
 *
 * Tab state is persisted in localStorage under `storageKey`.
 * The same key is used across all LanguageTabGroup instances on the page
 * so that switching language in one place updates all.
 *
 * JS in main.ts drives the switching behaviour.
 * If JS is disabled, the first tab (Go) is shown via CSS.
 */
import CodeBlock from './CodeBlock.astro';
import type { HelloWorldExample } from '../data/hello-world';

interface Props {
  examples: HelloWorldExample[];
  storageKey?: string;
  groupId?: string; // base id for tab/panel aria linkage
}

const {
  examples,
  storageKey = 'cyoda-lang',
  groupId = 'lang',
} = Astro.props;
---

<div
  class="lang-tabs"
  data-lang-tab-group
  data-storage-key={storageKey}
>
  <!-- Tab list -->
  <div
    class="lang-tabs__tablist"
    role="tablist"
    aria-label="Programming language"
  >
    {examples.map((ex, i) => (
      <button
        class="lang-tabs__tab"
        role="tab"
        id={`${groupId}-tab-${i}`}
        aria-controls={`${groupId}-panel-${i}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        data-lang={ex.language}
        type="button"
      >
        {ex.language}
      </button>
    ))}
  </div>

  <!-- Tab panels -->
  {examples.map((ex, i) => (
    <div
      class:list={['lang-tabs__panel', i === 0 && 'is-active']}
      role="tabpanel"
      id={`${groupId}-panel-${i}`}
      aria-labelledby={`${groupId}-tab-${i}`}
      aria-hidden={i === 0 ? 'false' : 'true'}
    >
      <CodeBlock
        code={ex.code}
        language={ex.langId}
      />
    </div>
  ))}
</div>
