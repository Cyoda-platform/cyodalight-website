---
/**
 * ConsumptionModel — three ways to use Cyoda.
 * Run it yourself / Cyoda Cloud / Enterprise Cyoda
 * Spec reference: section 14, section 23.
 *
 * Static CSS-rendered. No SVG required — pure HTML + CSS.
 * Reuses .progression layout. No arrows — three options are not sequential.
 */
import { site } from '../data/site';
---

<section
  class="section"
  id="how-to-use"
  aria-labelledby="how-to-use-heading"
>
  <div class="container">
    <h2 class="section-heading" id="how-to-use-heading">
      Three ways to use Cyoda
    </h2>

    <div class="progression">
      <div class="progression__diagram" role="list" aria-label="Cyoda deployment options">
        <!-- Option 1: Run it yourself -->
        <div class="progression__stage" role="listitem">
          <div class="progression__stage-label">Run it yourself</div>
          <div class="progression__stage-title">Free &middot; Apache 2.0</div>
          <p class="progression__stage-desc">
            Install the open-source binary and run Cyoda on your own machine
            or infrastructure. Local development, self-hosting, and
            experimentation. No account required.
          </p>
          <div class="progression__stage-cta">
            <a
              href={site.docsQuickstart}
              class="btn btn--text"
              target="_blank"
              rel="noopener noreferrer"
            >
              Install locally &rarr;
            </a>
          </div>
        </div>

        <!-- Option 2: Cyoda Cloud -->
        <div class="progression__stage progression__stage--highlight" role="listitem">
          <div class="progression__stage-label">Cyoda Cloud</div>
          <div class="progression__stage-title">Hosted SaaS</div>
          <p class="progression__stage-desc">
            Managed, hosted infrastructure. No binary to install,
            no cluster to operate. Get started immediately.
          </p>
          <div class="progression__stage-cta">
            <a
              href={site.cyodaCloud}
              class="btn btn--primary"
            >
              Try Cyoda Cloud &rarr;
            </a>
          </div>
        </div>

        <!-- Option 3: Enterprise Cyoda -->
        <div class="progression__stage" role="listitem">
          <div class="progression__stage-label">Enterprise Cyoda</div>
          <div class="progression__stage-title">Scalable deployment</div>
          <p class="progression__stage-desc">
            Larger-scale infrastructure with enterprise support, SLA,
            and dedicated engagement for organisations with advanced
            operational requirements.
          </p>
          <div class="progression__stage-cta">
            <a
              href={site.cyoda}
              class="btn btn--text"
            >
              Talk to us &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
