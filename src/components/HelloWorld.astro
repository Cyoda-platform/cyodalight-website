---
/**
 * HelloWorld — language-tabbed code example with framing text.
 * Spec reference: section 12, section 23.
 *
 * Tab state is persisted in localStorage (shared key with any other
 * LanguageTabGroup instances on the page).
 *
 * Code examples use illustrative API signatures.
 * Verify import paths against published client libraries before launch.
 */
import LanguageTabGroup from './LanguageTabGroup.astro';
import { helloWorldExamples } from '../data/hello-world';
import { site } from '../data/site';
---

<section
  class="section section--alt"
  id="hello-world"
  aria-labelledby="hello-world-heading"
>
  <div class="container">
    <div class="two-col">
      <!-- Left: framing -->
      <div>
        <h2 class="section-heading" id="hello-world-heading">Hello World</h2>

        <p class="hello-world__framing">
          One entity, one workflow, two transitions, one result.
        </p>

        <div class="prose">
          <p>
            This example creates a <code>Greeting</code> entity in the
            <code>PENDING</code> state, then drives a lifecycle transition
            based on the hour of day. Cyoda enforces that only valid
            transitions are allowed and records each one immutably.
          </p>
          <p class="hello-world__note">
            Import paths are illustrative — see
            <a href={site.docs} target="_blank" rel="noopener noreferrer">docs.cyoda.net</a>
            for the current client libraries.
          </p>
        </div>

        <a
          href={site.docsQuickstart}
          class="hello-world__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          &rarr; Full quick start on docs.cyoda.net
        </a>
      </div>

      <!-- Right: language-tabbed code -->
      <div>
        <LanguageTabGroup
          examples={helloWorldExamples}
          storageKey="cyoda-lang"
          groupId="hello-world"
        />
      </div>
    </div>
  </div>
</section>
