---
/**
 * NavBar — sticky 56px header with nav links and mobile hamburger.
 * Spec reference: section 8, section 23.
 *
 * GitHub star count is fetched client-side by main.ts.
 * If the fetch fails, the star count span is hidden gracefully.
 */
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<header class="navbar" role="banner">
  <div class="container">
    <nav class="navbar__inner" aria-label="Main navigation">
      <!-- Wordmark -->
      <a href={base} class="navbar__logo" aria-label="Cyoda home">
        <span class="navbar__wordmark">
          <span class="navbar__wordmark-cyoda">Cyoda</span>
        </span>
      </a>

      <!-- Desktop nav links -->
      <ul class="navbar__links" role="list">
        <li>
          <a href={site.docs} class="navbar__link">
            Docs
          </a>
        </li>
        <li>
          <a
            href={site.github}
            class="navbar__link navbar__github"
            id="nav-github-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
            <span
              class="navbar__star-count"
              id="github-star-count"
              aria-label="GitHub stars"
              style="display:none"
            ></span>
          </a>
        </li>
        <li>
          <a href={site.cyodaCloud} class="navbar__link">
            Cyoda Cloud
          </a>
        </li>
        <li>
          <a href={site.cyoda} class="navbar__link">
            Enterprise Cyoda
          </a>
        </li>
      </ul>

      <!-- Mobile hamburger button -->
      <button
        class="navbar__hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="navbar-drawer"
        id="navbar-hamburger"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile drawer -->
<div
  class="navbar__drawer"
  id="navbar-drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="false"
>
  <ul class="navbar__drawer-links" role="list">
    <li>
      <a href={site.docs} class="navbar__link">Docs</a>
    </li>
    <li>
      <a href={site.github} class="navbar__link" target="_blank" rel="noopener noreferrer">GitHub</a>
    </li>
    <li>
      <a href={site.cyodaCloud} class="navbar__link">Cyoda Cloud</a>
    </li>
    <li>
      <a href={site.cyoda} class="navbar__link">Enterprise Cyoda</a>
    </li>
  </ul>
</div>
