---
/**
 * index.astro — Cyoda homepage.
 *
 * Section order is fixed per spec section 6:
 *   1. Header / nav        — in BaseLayout
 *   2. Hero                — HeroSection
 *   3. Proof bar           — ProofBar
 *   4. What it is          — WhatItIs
 *   5. Hello World         — HelloWorld
 *   6. Key capabilities    — FeatureGrid
 *   7. Start local, deploy — ProgressionDiagram
 *   8. FAQ                 — FAQSection
 *   9. Final CTA           — FinalCTA
 *  10. Footer              — in BaseLayout
 *
 * This file contains only section composition and data plumbing.
 * No layout logic lives here.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import WhatItIs from '../components/WhatItIs.astro';
import HelloWorld from '../components/HelloWorld.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import ProgressionDiagram from '../components/ProgressionDiagram.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTA from '../components/FinalCTA.astro';

import { features } from '../data/features';
---

<BaseLayout>
  <!-- 2. Hero -->
  <HeroSection />

  <!-- 3. Proof bar -->
  <ProofBar />

  <!-- 4. What it is -->
  <WhatItIs />

  <!-- 5. Hello World -->
  <HelloWorld />

  <!-- 6. Key capabilities -->
  <section
    class="section"
    id="capabilities"
    aria-labelledby="capabilities-heading"
  >
    <div class="container">
      <h2 class="section-heading" id="capabilities-heading">What you get</h2>
      <FeatureGrid features={features} />
    </div>
  </section>

  <!-- 7. Start local, deploy later -->
  <ProgressionDiagram />

  <!-- 8. FAQ -->
  <FAQSection />

  <!-- 9. Final CTA -->
  <FinalCTA />
</BaseLayout>
