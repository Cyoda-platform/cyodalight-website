---
/**
 * index.astro — Cyoda homepage.
 *
 * Section order:
 *   1. Header / nav        — in BaseLayout
 *   2. Hero                — HeroSection
 *   3. Proof bar           — ProofBar
 *   4. AI agent install    — AgentInstallTabs
 *   5. What it is          — WhatItIs
 *   6. Quick start         — QuickStart
 *   7. Key capabilities    — FeatureGrid
 *   8. Growth path         — GrowthPath
 *   9. Three ways to use   — ProgressionDiagram
 *  10. FAQ                 — FAQSection
 *  11. Final CTA           — FinalCTA
 *  12. Footer              — in BaseLayout
 *
 * This file contains only section composition and data plumbing.
 * No layout logic lives here.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProofBar from '../components/ProofBar.astro';
import AgentInstallTabs from '../components/AgentInstallTabs.astro';
import WhatItIs from '../components/WhatItIs.astro';
import QuickStart from '../components/QuickStart.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import GrowthPath from '../components/GrowthPath.astro';
import ProgressionDiagram from '../components/ProgressionDiagram.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTA from '../components/FinalCTA.astro';

import { features } from '../data/features';
---

<BaseLayout>
  <!-- 2. Hero -->
  <HeroSection />

  <!-- 3. Proof bar -->
  <ProofBar />

  <!-- 4. AI coding agent install paths -->
  <AgentInstallTabs />

  <!-- 5. What it is -->
  <WhatItIs />

  <!-- 6. Install and get started -->
  <QuickStart />

  <!-- 7. Key capabilities -->
  <section
    class="section"
    id="capabilities"
    aria-labelledby="capabilities-heading"
  >
    <div class="container">
      <h2 class="section-heading" id="capabilities-heading">What you get</h2>
      <FeatureGrid features={features} />
    </div>
  </section>

  <!-- 8. Growth path — runtime mode progression -->
  <GrowthPath />

  <!-- 9. Three ways to use Cyoda -->
  <ProgressionDiagram />

  <!-- 10. FAQ -->
  <FAQSection />

  <!-- 11. Final CTA -->
  <FinalCTA />
</BaseLayout>
